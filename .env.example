# Copy to .env.local and fill in. Used by the serverless proxy in api/detect.ts.
# The key is NEVER exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the vision model (default: claude-opus-4-8).
# Cost lever — claude-haiku-4-5 or claude-sonnet-5 also support vision.
# PAWSCAN_MODEL=claude-opus-4-8

# Required for native iOS builds. Point this at your deployed serverless detect endpoint.
# Example: VITE_DETECT_API_URL=https://your-vercel-app.vercel.app/api/detect
# VITE_DETECT_API_URL=
