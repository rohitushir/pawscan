# Copy to .env.local and fill in. Used by the serverless proxy in api/detect.ts.
# The key is NEVER exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the vision model (default: claude-opus-4-8).
# Cost lever — claude-haiku-4-5 or claude-sonnet-5 also support vision.
# PAWSCAN_MODEL=claude-opus-4-8

# Required for native iOS builds. Point this at your deployed serverless detect endpoint.
# Example: VITE_DETECT_API_URL=https://your-vercel-app.vercel.app/api/detect
# VITE_DETECT_API_URL=

# --- Abuse protection (all optional) ---------------------------------------
# Rate limit (defaults: 20 requests / 60000 ms per IP).
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=60000

# Global rate limit via Upstash Redis (REST). When set, the limit is enforced
# across all serverless instances; without it, the limiter is per-instance.
# Create a free DB at upstash.com and copy the REST URL + token.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Shared token. When set on the server, the client must send the SAME value as
# VITE_PAWSCAN_APP_TOKEN so its bundle includes the matching x-app-token header.
# Deters casual abuse; not strong auth (the token ships in the client bundle).
# PAWSCAN_APP_TOKEN=some-long-random-string
# VITE_PAWSCAN_APP_TOKEN=some-long-random-string
