{
  "name": "pawscan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "proxy": "tsx scripts/dev-proxy.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
